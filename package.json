{
  "name": "tsumo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w @tsumo/engine build && npm run -w tsumo-cli build",
    "typecheck": "npm run -w @tsumo/engine build && npm run -w tsumo-cli typecheck",
    "test": "npm run -w @tsumo/engine test",
    "selftest": "bash ./scripts/selftest.sh",
    "verify-all": "bash ./scripts/verify-all.sh"
  },
  "devDependencies": {
    "@tsonic/core": "10.0.41",
    "@tsonic/dotnet": "10.0.41",
    "@tsonic/js": "10.0.49",
    "@tsonic/nodejs": "file:../nodejs/versions/10",
    "@tsonic/tsbindgen": "0.7.52",
    "tsonic": "0.0.76",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
