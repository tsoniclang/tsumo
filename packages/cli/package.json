{
  "name": "tsumo-cli",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "restore": "${TSONIC_BIN:-tsonic} restore",
    "typecheck": "${TSONIC_BIN:-tsonic} restore && tsc -p tsconfig.json",
    "build": "${TSONIC_BIN:-tsonic} build",
    "build:aot": "${TSONIC_BIN:-tsonic} build -c tsonic.aot.json",
    "dev": "${TSONIC_BIN:-tsonic} run -- --help"
  }
}
