{
  "name": "@tsumo/engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./index.js": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "src/**/*.ts",
    "tsonic.package.json"
  ],
  "scripts": {
    "restore": "tsonic restore",
    "typecheck": "tsonic restore && tsc -p tsconfig.json",
    "build": "tsonic restore && tsonic build",
    "test": "tsonic test"
  }
}
